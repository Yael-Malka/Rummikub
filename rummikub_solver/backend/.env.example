# Server Configuration
HOST=0.0.0.0
PORT=8000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=31660
REDIS_TTL_SECONDS=3600

# Security & JWT Configuration
# Run `openssl rand -hex 32` to generate a secure secret key
SECRET_KEY=super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60


# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://rummikub:rummikub123@localhost:30432/rummikub_db

# S3 / MinIO Configuration
S3_ENDPOINT_URL=http://localhost:30900
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_NAME=rummikub-boards

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:31660/0
CELERY_RESULT_BACKEND=redis://localhost:31660/0

# Processing Timeout Configuration
PROCESSING_TIMEOUT_SECONDS=120
PROCESSING_TIMEOUT_GRACE_SECONDS=15

# SMTP / Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
GMAIL_RUMMIKUB_EMAIL_ADDRESS=
GMAIL_RUMMIKUB_APP_PASSWORD=
SMTP_FROM=Rummikub Assistant <noreply@rummikub.app>
FRONTEND_URL=http://localhost:5180
