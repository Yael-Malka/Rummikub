{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "flutter-run-device",
      "type": "shell",
      "command": "/Users/brix/Documents/flutter/bin/flutter",
      "args": [
        "run",
        "-d",
        "RF8N60HJ9MK",
        "--disable-service-auth-codes"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "flutter",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Launching lib/main.dart",
          "endsPattern": "(Flutter run key commands|Syncing files to device)"
        }
      }
    }
  ]
}
